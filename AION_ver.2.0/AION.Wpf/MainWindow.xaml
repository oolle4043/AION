<Window x:Class="AION.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="파괴 아툴 수집기"
        Width="1020"
        Height="700"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="8">
            <Border DockPanel.Dock="Right"
                    Width="190"
                    Padding="20,4,8,4"
                    Background="#F5F6F8">
                <TextBlock x:Name="StatusTextBlock"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#4C5866"
                           Text="● 대기 중" />
            </Border>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="RunStopButton" Width="90" Height="30" Margin="0,0,6,0" Content="실행" Click="RunStopButton_Click" />
                <Button x:Name="ManageTargetButton" Width="100" Height="30" Margin="0,0,6,0" Content="추가/삭제" Click="ManageTargetButton_Click" />
                <Button x:Name="OpenListButton" Width="125" Height="30" Margin="0,0,6,0" Content="레기온 리스트" Click="OpenListButton_Click" />
                <Button x:Name="OpenResultFolderButton" Width="130" Height="30" Margin="0,0,6,0" Content="결과 폴더 열기" Click="OpenResultFolderButton_Click" />
                <Button x:Name="SettingsButton" Width="90" Height="30" Margin="0,0,6,0" Content="설정" Click="SettingsButton_Click" />
                <Button x:Name="InstallBrowserButton" Width="158" Height="30" Content="필수패키지 설치" Click="InstallBrowserButton_Click" />
            </StackPanel>
        </DockPanel>

        <TextBox x:Name="LogTextBox"
                 Grid.Row="1"
                 Margin="8,0,8,0"
                 Padding="4"
                 FontFamily="Consolas"
                 FontSize="10"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" />

        <Grid Grid.Row="2" Background="#F6F6F8">
            <TextBlock HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       FontSize="11"
                       FontStyle="Italic"
                       Foreground="#707078"
                       Text="Made by CJJ" />
        </Grid>
    </Grid>
</Window>
