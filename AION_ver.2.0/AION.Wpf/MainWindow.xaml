<Window x:Class="AION.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="파괴 아툴 수집기"
        Width="620"
        Height="560"
        MinWidth="600"
        MinHeight="430"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#172231" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1D2A3A" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#314256" />
        <SolidColorBrush x:Key="TextBrush" Color="#D9E5F4" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8392A8" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#405268" />
            <Setter Property="Background" Value="#253449" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A506D" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7190B4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203047" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#35C47E" />
            <Setter Property="BorderBrush" Value="#61D99E" />
            <Setter Property="Foreground" Value="#092115" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#54E39B" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8EF1BD" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#24A96A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F07F86" />
            <Setter Property="BorderBrush" Value="#F7A0A5" />
            <Setter Property="Foreground" Value="#2B080B" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF9CA2" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFC0C3" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D96670" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Background" Value="#1E2B3B" />
            <Setter Property="Foreground" Value="#9BAAC0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="PillTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#AFC0D6" />
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Margin="10"
                Background="#172231"
                CornerRadius="14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  Direction="270"
                                  Opacity="0.24"
                                  ShadowDepth="2"
                                  Color="#050B13" />
            </Border.Effect>
        </Border>

        <Border x:Name="WindowFrame"
                Margin="10"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="#5471A8"
                BorderThickness="1"
                CornerRadius="14"
                SnapsToDevicePixels="True">
            <Border.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Border Width="{Binding ActualWidth, ElementName=WindowFrame}"
                                Height="{Binding ActualHeight, ElementName=WindowFrame}"
                                Background="Black"
                                CornerRadius="14" />
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.OpacityMask>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
                <RowDefinition Height="24" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#101927">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="38"
                        Height="26"
                        Margin="8,0,7,0"
                        VerticalAlignment="Center"
                        Background="#5E82D8"
                        CornerRadius="7">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="파괴" />
                </Border>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="RunStopButton"
                            Width="54"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="실행"
                            Click="RunStopButton_Click" />
                    <Button x:Name="ManageTargetButton"
                            Width="74"
                            Content="추가/삭제"
                            Click="ManageTargetButton_Click" />
                    <Button x:Name="OpenListButton"
                            Width="86"
                            Content="레기온"
                            Click="OpenListButton_Click" />
                    <Button x:Name="OpenResultFolderButton"
                            Width="74"
                            Content="결과"
                            Click="OpenResultFolderButton_Click" />
                    <Button x:Name="InstallBrowserButton"
                            Width="82"
                            Content="패키지"
                            Click="InstallBrowserButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource IconButtonStyle}"
                            Content="⚙"
                            ToolTip="설정"
                            Click="SettingsButton_Click" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="—"
                            ToolTip="최소화"
                            Click="MinimizeButton_Click" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="×"
                            ToolTip="닫기"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Background="{StaticResource SurfaceAltBrush}">
                <TextBlock x:Name="StatusTextBlock"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#DDA64E"
                           Text="● 대기 중" />
            </Grid>

            <Grid Grid.Row="2" Background="#172231">
                <TextBox x:Name="LogTextBox"
                         Margin="10"
                         Padding="12"
                         FontFamily="Consolas"
                         FontSize="11"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="#182435"
                         BorderBrush="#25364B"
                         BorderThickness="1"
                         Foreground="#9EADC2"
                         CaretBrush="#D9E5F4" />

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Visibility="Collapsed"
                            Opacity="0.36">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="24"
                               Foreground="#7D8CA4"
                               Text="⌘" />
                    <TextBlock HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="#8B9AB0"
                               Text="로그 대기 중" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3" Background="#121D2B">
                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="Made by CJJ" />
            </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
