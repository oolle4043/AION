<Window x:Class="AION.Party.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="AION Party"
        Width="860"
        Height="780"
        MinWidth="820"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#172231" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1D2A3A" />
        <SolidColorBrush x:Key="TextBrush" Color="#D9E5F4" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8392A8" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#405268" />
            <Setter Property="Background" Value="#253449" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A506D" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7190B4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203047" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="Width" Value="68" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#253449" />
            <Setter Property="BorderBrush" Value="#405268" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#35C47E" />
            <Setter Property="BorderBrush" Value="#61D99E" />
            <Setter Property="Foreground" Value="#092115" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#1E2B3B" />
            <Setter Property="Foreground" Value="#9BAAC0" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Margin="10"
                Background="#172231"
                CornerRadius="14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  Direction="270"
                                  Opacity="0.24"
                                  ShadowDepth="2"
                                  Color="#050B13" />
            </Border.Effect>
        </Border>

        <Border x:Name="WindowFrame"
                Margin="10"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="#5471A8"
                BorderThickness="1"
                CornerRadius="14"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="26" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#101927">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <Button x:Name="GenerateButton"
                                Width="88"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="&#xD30C;&#xD2F0; &#xC0DD;&#xC131;"
                                Click="GenerateButton_Click" />
                        <Button x:Name="OpenListButton"
                                Width="88"
                                Content="list.txt"
                                Click="OpenListButton_Click" />
                        <Button x:Name="OpenResultButton"
                                Width="88"
                                Content="&#xACB0;&#xACFC; &#xC5F4;&#xAE30;"
                                Click="OpenResultButton_Click" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,4,0">
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource IconButtonStyle}"
                                Content="&#x2699;"
                                ToolTip="&#xC124;&#xC815;"
                                Click="SettingsButton_Click" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="_"
                                ToolTip="&#xCD5C;&#xC18C;&#xD654;"
                                Click="MinimizeButton_Click" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="X"
                                ToolTip="&#xB2EB;&#xAE30;"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Background="{StaticResource SurfaceAltBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#DDA64E"
                               Text="&#xB300;&#xAE30; &#xC911;" />
                    <TextBlock x:Name="ResultPathTextBlock"
                               Grid.Column="1"
                               Margin="18,0,12,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#69D1A5"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <Grid Grid.Row="2" Background="#172231">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="155" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBox x:Name="ListPreviewTextBox"
                             Grid.Row="0"
                             Margin="10,10,10,5"
                             Padding="10"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Background="#182435"
                             BorderBrush="#25364B"
                             BorderThickness="1"
                             Foreground="#B8C8DC"
                             CaretBrush="#D9E5F4" />

                    <TextBox x:Name="ResultTextBox"
                             Grid.Row="1"
                             Margin="10,5,10,10"
                             Padding="12"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Background="#182435"
                             BorderBrush="#25364B"
                             BorderThickness="1"
                             Foreground="#D9E5F4"
                             CaretBrush="#D9E5F4" />
                </Grid>

                <Grid Grid.Row="3" Background="#121D2B">
                    <TextBlock HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Made by CJJ" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
